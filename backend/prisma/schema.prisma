generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Society {
  id         String      @id @default(uuid())
  name       String
  address    String
  zipCode    String?
  logo       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  complaints Complaint[]
  entryLogs  EntryLog[]
  flats      Flat[]
  notices    Notice[]
  passes     Pass[]
  users      User[]
}

model Flat {
  id         String      @id @default(uuid())
  number     String
  floor      Int
  societyId  String
  complaints Complaint[]
  entryLogs  EntryLog[]
  society    Society     @relation(fields: [societyId], references: [id])
  passes     Pass[]
  users      User[]

  @@unique([number, societyId])
  @@index([societyId])
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  password        String
  phone           String?
  role            Role           @default(RESIDENT)
  status          UserStatus     @default(PENDING)
  flatId          String?
  societyId       String
  fcmToken        String?
  profilePicture  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  complaints      Complaint[]
  guardEntries    EntryLog[]     @relation("GuardEntries")
  residentEntries EntryLog[]     @relation("ResidentEntries")
  notices         Notice[]
  notifications   Notification[]
  passes          Pass[]
  assignedComplaints Complaint[] @relation("AssignedComplaints")
  flat            Flat?          @relation(fields: [flatId], references: [id])
  society         Society        @relation(fields: [societyId], references: [id])

  @@index([societyId, status])
  @@index([flatId])
}

model Pass {
  id           String      @id @default(uuid())
  type         PassType
  visitorName  String
  visitorPhone String?
  visitorType  VisitorType
  notes        String?
  visitorPhoto String?
  qrToken      String?     @unique
  expiresAt    DateTime?
  status       PassStatus  @default(ACTIVE)
  allowedDays  Int[]
  windowStart  String?
  windowEnd    String?
  validFrom    DateTime?
  validUntil   DateTime?
  residentId   String
  flatId       String
  societyId    String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  entries      EntryLog[]
  flat         Flat        @relation(fields: [flatId], references: [id])
  resident     User        @relation(fields: [residentId], references: [id])
  society      Society     @relation(fields: [societyId], references: [id])

  @@index([residentId])
  @@index([societyId])
  @@index([flatId])
  @@index([status])
}

model EntryLog {
  id           String      @id @default(uuid())
  visitorName  String
  visitorPhone String?
  visitorType  VisitorType
  method       EntryMethod
  status       EntryStatus
  notes        String?
  visitorIdUrl String?
  passId       String?
  guardId      String
  residentId   String?
  flatId       String
  societyId    String
  entryTime    DateTime    @default(now())
  exitTime     DateTime?
  flat         Flat        @relation(fields: [flatId], references: [id])
  guard        User        @relation("GuardEntries", fields: [guardId], references: [id])
  pass         Pass?       @relation(fields: [passId], references: [id])
  resident     User?       @relation("ResidentEntries", fields: [residentId], references: [id])
  society      Society     @relation(fields: [societyId], references: [id])

  @@index([societyId, entryTime])
  @@index([flatId])
  @@index([guardId])
  @@index([passId])
}

model Notice {
  id        String         @id @default(uuid())
  title     String
  body      String
  category  NoticeCategory
  priority  NoticePriority
  isPinned  Boolean        @default(false)
  authorId  String
  societyId String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  author    User           @relation(fields: [authorId], references: [id])
  society   Society        @relation(fields: [societyId], references: [id])

  @@index([societyId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

model Complaint {
  id          String            @id @default(uuid())
  title       String
  description String
  category    ComplaintCategory
  priority    PriorityLevel     @default(LOW)
  status      ComplaintStatus   @default(OPEN)
  photos      String[]
  closingNote String?
  assignedToId String?
  flatId      String
  userId      String
  societyId   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  assignedTo  User?             @relation("AssignedComplaints", fields: [assignedToId], references: [id])
  flat        Flat              @relation(fields: [flatId], references: [id])
  society     Society           @relation(fields: [societyId], references: [id])
  user        User              @relation(fields: [userId], references: [id])

  @@index([societyId])
  @@index([userId])
  @@index([assignedToId])
}

enum Role {
  ADMIN
  RESIDENT
  SECURITY
  SERVICE
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ComplaintStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
}

enum ComplaintCategory {
  PLUMBING
  ELECTRICAL
  CLEANING
  SECURITY
  OTHER
}

enum EntryStatus {
  PENDING
  APPROVED
  REJECTED
  SCANNED
  EXPIRED
}

enum PassType {
  ONE_TIME
  RECURRING
}

enum PassStatus {
  ACTIVE
  USED
  REVOKED
  EXPIRED
}

enum VisitorType {
  DELIVERY
  CAB
  HOUSEHOLD_WORKER
  GUEST
  SERVICE_PROFESSIONAL
}

enum EntryMethod {
  QR_SCAN
  MANUAL_LOOKUP
  LIVE_APPROVAL
}

enum NoticeCategory {
  GENERAL
  MAINTENANCE
  EVENT
  EMERGENCY
}

enum NoticePriority {
  NORMAL
  HIGH
  URGENT
}
